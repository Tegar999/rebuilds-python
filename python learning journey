def count_score(subjects):
    score = 0

    for n in subjects:
        if n == "math":
            score += 3
            print(n, "+3")
        elif n == "english":
            score += 2
            print(n, "+2")
        elif n == "python":
            score += 4
            print(n, "+4")
        elif n == "break":
            score -= 1
            print(n, "-1")

